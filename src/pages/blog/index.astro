---
import BaseLayout from "@layouts/BaseLayout.astro";
import Container from "@components/Container.astro";
import BlogPostCard from "@components/BlogPostCard.astro";
import { getHomepagePosts, displayTitle, displayDescription, formatDate } from "@lib/posts";
import { SITE } from "@lib/site";

const posts = await getHomepagePosts();
const [hero, ...rest] = posts;
const heroTitle = hero ? displayTitle(hero) : "";
const heroDesc = hero ? displayDescription(hero) : "";
---
<!-- Layout: gestapeld hero + gemengd 2+3 koloms grid -->
<BaseLayout
  title={`Blog — autotheorie tips | ${SITE.name}`}
  description="Artikelen en tips over het CBR theorie-examen, rijles, verkeersregels en alles rondom je rijbewijs."
>
  <section class="bg-[linear-gradient(160deg,var(--color-brand-900)_0%,var(--color-brand-700)_100%)] py-(--spacing-section)">
    <Container class="max-w-3xl text-center">
      <h1 class="text-5xl font-extrabold tracking-tight text-white">Autotheorie Blog</h1>
      <p class="mt-4 text-lg text-brand-100">Praktische tips, uitleg en nieuws om jou te helpen slagen.</p>
    </Container>
  </section>

  <Container class="py-(--spacing-section)">
    <!-- Hero artikel: groot bovenaan -->
    {hero && (
      <a href={`/${hero.id}/`} class="group mb-12 flex flex-col overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm hover:shadow-lg transition">
        {hero.data.featuredImage ? (
          <img src={hero.data.featuredImage} alt={heroTitle}
               width="1200" height="420" loading="eager" fetchpriority="high"
               class="h-64 w-full object-cover sm:h-80 transition duration-500 group-hover:brightness-95" />
        ) : (
          <div class="h-64 w-full bg-gradient-to-r from-brand-700 to-brand-500 sm:h-80 flex items-center justify-center">
            <span class="text-4xl font-extrabold text-white/20 tracking-widest">BLOG</span>
          </div>
        )}
        <div class="p-7">
          <div class="flex items-center gap-3 mb-2">
            <span class="text-xs font-bold uppercase tracking-widest text-brand-600">Meest recent</span>
            <span class="text-xs text-slate-400">{formatDate(hero.data.date)}</span>
          </div>
          <h2 class="text-2xl font-extrabold text-slate-900 group-hover:text-brand-700 sm:text-3xl">{heroTitle}</h2>
          {heroDesc && <p class="mt-2 max-w-3xl text-slate-600 line-clamp-2">{heroDesc}</p>}
        </div>
      </a>
    )}

    <!-- Overige artikelen: 2-koloms op tablet, 3 op desktop -->
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {rest.map((p) => <BlogPostCard post={p} />)}
    </div>
  </Container>
</BaseLayout>
