---
import BaseLayout from "@layouts/BaseLayout.astro";
import Container from "@components/Container.astro";
import Button from "@components/Button.astro";
import BlogPostCard from "@components/BlogPostCard.astro";
import { getRecentPosts } from "@lib/posts";
import { SITE } from "@lib/site";

const recent = await getRecentPosts(6);

const topics = [
  { title: "Verkeersborden oefenen", desc: "Quiz met directe feedback. Leer elk bord herkennen.", href: "/verkeersborden-oefenen/", cta: "Start de quiz" },
  { title: "Voorrangsregels", desc: "Van haaientanden tot gelijkwaardige kruispunten — volledig uitgelegd.", href: "/voorrangsregels/", cta: "Lees uitleg" },
  { title: "Motor theorie", desc: "Aparte stof voor het motorrijbewijs, met examentips.", href: "/motor-theorie/", cta: "Naar motor theorie" },
  { title: "Scooter theorie", desc: "Alles voor het AM-rijbewijs: regels, borden en examenstrategie.", href: "/scooter-theorie/", cta: "Naar scooter theorie" },
];

const videoFeatures = [
  "35 videohoofdstukken — alle CBR-stof",
  "±4 uur video, jouw tempo",
  "Lifetime toegang, alle apparaten",
  "Ezelsbruggetjes & CBR-trucs",
];

const jsonld = {
  "@context": "https://schema.org",
  "@graph": [
    { "@type": "Organization", "@id": `${SITE.url}/#org`, name: SITE.name, url: SITE.url },
    { "@type": "WebSite", "@id": `${SITE.url}/#website`, url: SITE.url, name: SITE.name, publisher: { "@id": `${SITE.url}/#org` }, inLanguage: "nl-NL" },
  ],
};
---
<BaseLayout
  title="Autotheorie.nl — Video cursus & gratis oefenen voor je CBR-examen"
  description="Slaag in één keer voor je autotheorie-examen. Videocursus met 35 hoofdstukken, gratis verkeersborden oefenen en alle theorie op één plek."
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonld)} is:inline />

  <!-- Hero -->
  <section class="-mt-16 pt-16 md:-mt-[5rem] md:pt-[5rem] bg-white">
    <Container class="grid items-center gap-12 py-(--spacing-section) lg:grid-cols-2">
      <div>
        <span class="inline-flex items-center gap-1.5 rounded-full bg-brand-50 px-3 py-1 text-sm font-semibold text-brand-700">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><circle cx="7" cy="7" r="7" fill="#059669"/><path d="M4 7.2L6.2 9.4L10 5" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          88% van onze cursisten slaagt in één keer
        </span>
        <h1 class="mt-5 text-4xl font-extrabold tracking-tight text-slate-900 sm:text-5xl">
          Slaag in één keer<br />voor je <span class="text-brand-600">autotheorie.</span>
        </h1>
        <p class="mt-5 max-w-xl text-lg text-slate-600">
          De complete video cursus + gratis oefenmateriaal. Alles wat je nodig hebt
          voor je CBR-examen — op jouw tempo, op elk apparaat.
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <Button href="/video-cursus/" variant="primary">Bekijk video cursus</Button>
          <Button href="/verkeersborden-oefenen/" variant="secondary">Gratis oefenen</Button>
        </div>
        <p class="mt-4 text-sm text-slate-400">Niet goed? Geld terug. Nationaal gemiddelde: 50%.</p>
      </div>

      <!-- Video cursus card -->
      <div class="rounded-2xl border-2 border-brand-500 bg-white p-6 shadow-md">
        <div class="flex items-center justify-between">
          <p class="text-xs font-bold uppercase tracking-widest text-brand-600">Video Cursus</p>
          <span class="rounded-full bg-brand-600 px-2.5 py-0.5 text-xs font-bold text-white">Tijdelijke aanbieding</span>
        </div>
        <div class="mt-3 flex items-end gap-3">
          <span class="text-4xl font-extrabold text-slate-900">€ 29,99</span>
          <span class="mb-1 text-sm text-slate-400 line-through">€ 69,99</span>
        </div>
        <ul class="mt-4 space-y-2.5">
          {videoFeatures.map((f) => (
            <li class="flex items-center gap-2.5 text-sm font-medium text-slate-700">
              <span class="flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-brand-100">
                <svg width="10" height="10" viewBox="0 0 12 12" fill="none" aria-hidden="true">
                  <path d="M2 6.3L4.5 8.8L10 3" stroke="#047857" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
              {f}
            </li>
          ))}
        </ul>
        <a href="/video-cursus/" class="mt-5 flex w-full items-center justify-center rounded-xl bg-brand-600 px-5 py-3 text-sm font-bold text-white transition hover:bg-brand-700">
          Direct starten →
        </a>
        <p class="mt-3 text-center text-xs text-slate-400">Eenmalig · geen abonnement · alle apparaten</p>
      </div>
    </Container>
  </section>

  <!-- Stats bar -->
  <section class="bg-brand-700">
    <Container class="grid grid-cols-3 divide-x divide-brand-600 py-7 text-center">
      {[
        { value: "88%", label: "Slaagt in één keer" },
        { value: "35", label: "Videohoofdstukken" },
        { value: "€29,99", label: "Eenmalig, lifetime toegang" },
      ].map((s) => (
        <div class="px-4">
          <div class="text-2xl font-extrabold text-white sm:text-3xl">{s.value}</div>
          <div class="mt-1 text-xs text-brand-200">{s.label}</div>
        </div>
      ))}
    </Container>
  </section>

  <!-- Topics grid -->
  <section class="bg-white">
    <Container class="py-(--spacing-section)">
      <h2 class="text-3xl font-extrabold tracking-tight text-slate-900">Gratis oefenen per onderwerp</h2>
      <p class="mt-2 text-slate-500">Kies een onderwerp en ga direct aan de slag — geen account nodig.</p>
      <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        {topics.map((t) => (
          <a
            href={t.href}
            class="group flex flex-col rounded-2xl border-l-4 border-brand-500 bg-slate-50 p-6 transition hover:bg-brand-50 hover:border-brand-600"
          >
            <h3 class="text-base font-bold text-slate-900 group-hover:text-brand-700">{t.title}</h3>
            <p class="mt-2 flex-1 text-sm text-slate-600">{t.desc}</p>
            <span class="mt-5 text-sm font-semibold text-brand-600 group-hover:text-brand-700">{t.cta} →</span>
          </a>
        ))}
      </div>
    </Container>
  </section>

  <!-- Internal links -->
  <section class="border-t border-slate-100 bg-slate-50">
    <Container class="py-12">
      <h2 class="text-2xl font-extrabold tracking-tight text-slate-900">Alles voor je theorie-examen</h2>
      <p class="mt-1 text-sm text-slate-500">Direct naar het onderwerp dat je nodig hebt.</p>
      <ul class="mt-5 grid gap-x-4 gap-y-1.5 text-sm sm:grid-cols-2 lg:grid-cols-4">
        {[
          { label: "Mijn CBR", href: "/mijn-cbr/" },
          { label: "Voorrangsregels", href: "/voorrangsregels/" },
          { label: "CBR slagingspercentage", href: "/cbr-slagingspercentage/" },
          { label: "Kosten rijbewijs", href: "/wat-kost-een-rijbewijs-ontdek-de-prijzen-hier/" },
          { label: "Motor theorie", href: "/motor-theorie/" },
          { label: "Scooter theorie", href: "/scooter-theorie/" },
          { label: "Gelijkwaardig kruispunt", href: "/gelijkwaardig-kruispunt/" },
          { label: "Verkeersregelaar tekens", href: "/verkeersregelaar/" },
          { label: "Rijbewijs aanvragen", href: "/rijbewijs-aanvragen/" },
          { label: "Theorie examen tips", href: "/theorie-examen-oefenen-arabisch-op-maat-gemaakt/" },
          { label: "Gevaarherkenning", href: "/gevaarherkenning/" },
          { label: "Haaientanden betekenis", href: "/haaientanden/" },
          { label: "Remafstand berekenen", href: "/remafstand-berekenen/" },
          { label: "Hoeveel fouten mag je maken", href: "/hoeveel-fouten-theorie-examen/" },
          { label: "Herexamen CBR", href: "/herexamen-cbr/" },
          { label: "Autotheorie in 1 dag", href: "/autotheorie-in-1-dag/" },
          { label: "Alle verkeersborden", href: "/alle-verkeersborden/" },
          { label: "Afrijden CBR", href: "/afrijden-cbr/" },
          { label: "Symbolen auto", href: "/symbolen-auto/" },
          { label: "Internationaal rijbewijs", href: "/internationaal-rijbewijs/" },
        ].map((l) => (
          <li>
            <a href={l.href} class="flex items-center gap-2 rounded-lg px-3 py-2 text-slate-700 transition hover:bg-white hover:text-brand-700">
              <span class="text-brand-500" aria-hidden="true">→</span>{l.label}
            </a>
          </li>
        ))}
      </ul>
    </Container>
  </section>

  <!-- Video cursus CTA band -->
  <section class="bg-brand-700">
    <Container class="flex flex-col items-center justify-between gap-5 py-12 text-center sm:flex-row sm:text-left">
      <div>
        <p class="text-xs font-bold uppercase tracking-widest text-brand-300">Video Cursus · Tijdelijke aanbieding</p>
        <h2 class="mt-1 text-2xl font-extrabold text-white">Slaag in één keer — <span class="text-brand-300">€ 29,99</span></h2>
        <p class="mt-1 text-brand-100">35 hoofdstukken · 4 uur video · lifetime toegang · geld-terug-garantie</p>
      </div>
      <a href="/video-cursus/" class="inline-flex shrink-0 items-center rounded-xl bg-white px-6 py-3 font-bold text-brand-700 transition hover:bg-brand-50">
        Bekijk de cursus →
      </a>
    </Container>
  </section>

  <!-- Latest from the blog -->
  {recent.length > 0 && (
    <section class="bg-white">
      <Container class="py-(--spacing-section)">
        <div class="flex items-end justify-between">
          <h2 class="text-3xl font-extrabold tracking-tight text-slate-900">Uit de blog</h2>
          <a href="/blog/" class="text-sm font-semibold text-brand-700 hover:underline">Alle artikelen →</a>
        </div>
        <div class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {recent.map((p, i) => <BlogPostCard post={p} eager={i === 0} />)}
        </div>
      </Container>
    </section>
  )}
</BaseLayout>
