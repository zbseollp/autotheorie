---
import BaseLayout from "@layouts/BaseLayout.astro";
import Container from "@components/Container.astro";
import Button from "@components/Button.astro";
---
<BaseLayout title="Pagina niet gevonden (404) | Autotheorie.nl" description="Deze pagina bestaat niet." noindex={true}>
  <Container class="max-w-2xl py-(--spacing-section) text-center">
    <p class="text-6xl font-extrabold text-brand-600">404</p>
    <h1 class="mt-4 text-3xl font-extrabold text-slate-900">Deze pagina bestaat niet</h1>
    <p class="mt-3 text-slate-600">De pagina die je zoekt is niet gevonden. Misschien is de URL veranderd. Ga terug naar de homepage of oefen alvast met de quiz.</p>
    <div class="mt-8 flex justify-center gap-3">
      <Button href="/" variant="primary">Terug naar home</Button>
      <Button href="/verkeersborden-oefenen/" variant="secondary">Start de quiz</Button>
    </div>
  </Container>
</BaseLayout>
