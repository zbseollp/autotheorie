---
import type { Post } from "@lib/posts";
import { displayTitle, displayDescription, formatDate } from "@lib/posts";
interface Props { post: Post; eager?: boolean }
const { post, eager = false } = Astro.props;
const { featuredImage: fmImage, featuredImageAlt, date } = post.data;
// Fallback: extract first <img src> from body when frontmatter has no image
const bodyImage = !fmImage
  ? post.body?.match(/<img[^>]+src=["']?([^"'\s>]+)["']?/i)?.[1]
  : undefined;
const featuredImage = fmImage ?? bodyImage;
const title = displayTitle(post);
const desc = displayDescription(post);
const href = `/${post.id}/`;
---
<article class="group flex gap-4 rounded-2xl border border-slate-200 bg-white p-4 transition hover:border-brand-200 hover:shadow-md sm:gap-5 sm:p-5">
  <a href={href} class="shrink-0" aria-label={title} aria-hidden="true" tabindex="-1">
    {featuredImage ? (
      <img
        src={featuredImage}
        alt={featuredImageAlt || title}
        width="160" height="120"
        loading={eager ? "eager" : "lazy"}
        decoding={eager ? "sync" : "async"}
        class="h-24 w-32 rounded-xl object-cover transition group-hover:scale-[1.03] sm:h-28 sm:w-40"
      />
    ) : (
      <div class="flex h-24 w-32 items-center justify-center rounded-xl bg-gradient-to-br from-brand-700 to-brand-500 sm:h-28 sm:w-40">
        <span class="text-xs font-bold text-white/80">AutoTheorie</span>
      </div>
    )}
  </a>
  <div class="flex min-w-0 flex-1 flex-col justify-between">
    <div>
      <time datetime={date.toISOString()} class="text-xs font-medium text-brand-700">{formatDate(date)}</time>
      <h2 class="mt-1 line-clamp-2 text-base font-bold leading-snug text-slate-900 sm:text-lg">
        <a href={href} class="hover:text-brand-700">{title}</a>
      </h2>
      {desc && <p class="mt-1 line-clamp-2 text-sm text-slate-500 hidden sm:block">{desc}</p>}
    </div>
    <span class="mt-2 text-xs font-semibold text-brand-700">Lees verder →</span>
  </div>
</article>
