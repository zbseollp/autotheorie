---
import Container from "@components/Container.astro";
import CurrentYear from "@components/CurrentYear.astro";
import { SITE } from "@lib/site";
import { getRecentPosts, displayTitle } from "@lib/posts";
const recent = (await getRecentPosts(4)).map((p) => ({ slug: p.id, title: displayTitle(p) }));
---
<footer class="mt-10 border-t-4 border-brand-500 bg-slate-900 text-slate-400">
  <Container class="grid gap-10 py-12 md:grid-cols-12">
    <div class="md:col-span-4">
      <a href="/" class="inline-flex items-center gap-2.5 text-white">
        <svg width="28" height="28" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <circle cx="16" cy="16" r="16" fill="#059669"/>
          <path d="M9 16.5L13.5 21L23 11.5" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <span class="font-display text-base font-extrabold">Autotheorie<span class="text-brand-400">.nl</span></span>
      </a>
      <p class="mt-3 text-sm leading-relaxed">
        Gratis autotheorie leren voor je CBR-examen. De slimste route naar je rijbewijs.
      </p>
    </div>

    <div class="md:col-span-3">
      <h3 class="text-xs font-semibold uppercase tracking-widest text-slate-500">Onderwerpen</h3>
      <ul class="mt-3 space-y-2 text-sm">
        <li><a class="transition hover:text-white" href="/mijn-cbr/">Mijn CBR</a></li>
        <li><a class="transition hover:text-white" href="/verkeersborden-oefenen/">Verkeersborden oefenen</a></li>
        <li><a class="transition hover:text-white" href="/voorrangsregels/">Voorrangsregels</a></li>
        <li><a class="transition hover:text-white" href="/cbr-slagingspercentage/">CBR slagingspercentage</a></li>
        <li><a class="transition hover:text-white" href="/kosten-theorie-examen-auto/">Kosten theorie examen</a></li>
        <li><a class="transition hover:text-white" href="/motor-theorie/">Motor theorie</a></li>
        <li><a class="transition hover:text-white" href="/gelijkwaardig-kruispunt/">Gelijkwaardig kruispunt</a></li>
        <li><a class="transition hover:text-white" href="/verkeersregelaar/">Verkeersregelaar tekens</a></li>
      </ul>
    </div>

    <div class="md:col-span-2">
      <h3 class="text-xs font-semibold uppercase tracking-widest text-slate-500">Info</h3>
      <ul class="mt-3 space-y-2 text-sm">
        <li><a class="transition hover:text-white" href="/video-cursus/">Video Cursus</a></li>
        <li><a class="transition hover:text-white" href="/mijn-account/">Mijn account</a></li>
        <li><a class="transition hover:text-white" href="/over-ons/">Over ons</a></li>
        <li><a class="transition hover:text-white" href="/contact/">Contact</a></li>
        <li><a class="transition hover:text-white" href="/sitemap/">Sitemap</a></li>
      </ul>
    </div>

    <div class="md:col-span-3">
      <h3 class="text-xs font-semibold uppercase tracking-widest text-slate-500">Recente artikelen</h3>
      <ul class="mt-3 space-y-2 text-sm">
        {recent.map((p) => (
          <li><a class="transition hover:text-white" href={`/${p.slug}/`}>{p.title}</a></li>
        ))}
      </ul>
    </div>
  </Container>

  <div class="border-t border-slate-800">
    <Container class="flex flex-col items-center justify-between gap-2 py-5 text-xs text-slate-600 sm:flex-row">
      <p>© <CurrentYear /> Autotheorie.nl. Alle rechten voorbehouden.</p>
      <p>Niet gelieerd aan CBR of de Rijksoverheid.</p>
    </Container>
  </div>
</footer>
